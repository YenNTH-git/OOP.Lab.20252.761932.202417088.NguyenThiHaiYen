+        Scanner sc = new Scanner(System.in);
+        Double num1 = sc.nextDouble();
+        Double num2 = sc.nextDouble();
+        System.out.println("Tong = " + (num1 + num2));
+        System.out.println("Hieu = " + (num1 - num2));
+        System.out.println("Tich = " + num1 * num2);
